# Copy to .env and set strong, unique values before first run.
# Never commit .env or put secrets in URLs.

# Required
APP_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password
APP_ADMIN_PASSWORD=change-this-admin-password
APP_PHARMACIST_PASSWORD=change-this-pharmacist-password
APP_CASHIER_PASSWORD=change-this-cashier-password

# Optional
SPRING_DATASOURCE_USERNAME=root
APP_SMS_API_KEY=
APP_WHATSAPP_API_TOKEN=
