# Copy to .env and set strong, unique values before first run.
# Never commit .env or put secrets in URLs.

# Required
APP_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Server
PORT=8086

# Database (sqlite is default — no external DB needed)
DB_DRIVER=sqlite
DB_DSN=data/medical_billing.db

# Demo user passwords
APP_ADMIN_PASSWORD=admin123
APP_PHARMACIST_PASSWORD=pharma123
APP_CASHIER_PASSWORD=cashier123

# Optional notifications
APP_SMS_API_KEY=
APP_WHATSAPP_API_TOKEN=

# Inventory alerts
APP_LOW_STOCK_THRESHOLD=10
APP_NEAR_EXPIRY_DAYS=30
